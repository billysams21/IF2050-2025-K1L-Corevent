<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.corevent.controller.ParticipantManagementViewController"
      spacing="10">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>
    
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Event Participants" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="statusFilter" promptText="Filter by Status"/>
        <Button fx:id="refreshButton" text="Refresh" onAction="#loadParticipants"/>
        <Button fx:id="exportButton" text="Export" onAction="#handleExport"/>
    </HBox>
    
    <TableView fx:id="participantsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="participantIdColumn" text="ID" prefWidth="100"/>
            <TableColumn fx:id="fullNameColumn" text="Full Name" prefWidth="150"/>
            <TableColumn fx:id="emailColumn" text="Email" prefWidth="200"/>
            <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="120"/>
            <TableColumn fx:id="institutionColumn" text="Institution" prefWidth="150"/>
            <TableColumn fx:id="ticketStatusColumn" text="Ticket Status" prefWidth="100"/>
            <TableColumn fx:id="attendanceStatusColumn" text="Attendance" prefWidth="100"/>
            <TableColumn fx:id="registrationDateColumn" text="Registration Date" prefWidth="150"/>
            <TableColumn fx:id="paymentStatusColumn" text="Payment" prefWidth="100"/>
            <TableColumn fx:id="amountPaidColumn" text="Amount Paid" prefWidth="100"/>
        </columns>
    </TableView>
    
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Label fx:id="totalParticipantsLabel" text="Total Participants: 0"/>
        <Label fx:id="presentParticipantsLabel" text="Present: 0"/>
        <Label fx:id="absentParticipantsLabel" text="Absent: 0"/>
    </HBox>
</VBox> 