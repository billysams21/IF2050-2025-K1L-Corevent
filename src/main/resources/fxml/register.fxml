<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.corevent.controller.RegisterController">
    <VBox alignment="CENTER" spacing="20.0" styleClass="root">
        <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/>
        </padding>

        <!-- Header -->
        <VBox alignment="CENTER" spacing="10.0">
            <Text styleClass="form-title" text="Create Account"/>
            <Text styleClass="app-subtitle" text="Join Corevent and start managing events"/>
        </VBox>

        <!-- Registration Form -->
        <VBox spacing="15.0" styleClass="login-container" maxWidth="400.0">
            
            <!-- Role Selection -->
            <VBox spacing="5.0">
                <Label styleClass="form-label" text="Account Type"/>
                <HBox spacing="20.0">
                    <RadioButton fx:id="committeeRadio" text="Committee" selected="true">
                        <toggleGroup>
                            <ToggleGroup fx:id="roleGroup"/>
                        </toggleGroup>
                    </RadioButton>
                    <RadioButton fx:id="participantRadio" text="Participant" toggleGroup="$roleGroup"/>
                </HBox>
            </VBox>

            <!-- Username -->
            <VBox spacing="5.0">
                <Label styleClass="form-label" text="Username"/>
                <TextField fx:id="usernameField" styleClass="form-field" promptText="Enter your username"/>
                <Label fx:id="usernameError" styleClass="error-label" visible="false"/>
            </VBox>

            <!-- Email -->
            <VBox spacing="5.0">
                <Label styleClass="form-label" text="Email"/>
                <TextField fx:id="emailField" styleClass="form-field" promptText="Enter your email"/>
                <Label fx:id="emailError" styleClass="error-label" visible="false"/>
            </VBox>

            <!-- Password -->
            <VBox spacing="5.0">
                <Label styleClass="form-label" text="Password"/>
                <PasswordField fx:id="passwordField" styleClass="form-field" promptText="Enter your password"/>
                <Label fx:id="passwordError" styleClass="error-label" visible="false"/>
            </VBox>

            <!-- Confirm Password -->
            <VBox spacing="5.0">
                <Label styleClass="form-label" text="Confirm Password"/>
                <PasswordField fx:id="confirmPasswordField" styleClass="form-field" promptText="Confirm your password"/>
                <Label fx:id="confirmPasswordError" styleClass="error-label" visible="false"/>
            </VBox>

            <!-- Full Name -->
            <VBox spacing="5.0">
                <Label styleClass="form-label" text="Full Name"/>
                <TextField fx:id="fullNameField" styleClass="form-field" promptText="Enter your full name"/>
                <Label fx:id="fullNameError" styleClass="error-label" visible="false"/>
            </VBox>

            <!-- Phone Number -->
            <VBox spacing="5.0">
                <Label styleClass="form-label" text="Phone Number"/>
                <TextField fx:id="phoneField" styleClass="form-field" promptText="Enter your phone number"/>
            </VBox>

            <!-- Committee-specific fields -->
            <VBox fx:id="committeeFields" spacing="15.0">
                <VBox spacing="5.0">
                    <Label styleClass="form-label" text="Department"/>
                    <TextField fx:id="departmentField" styleClass="form-field" promptText="Enter your department"/>
                </VBox>
                
                <VBox spacing="5.0">
                    <Label styleClass="form-label" text="Position"/>
                    <TextField fx:id="positionField" styleClass="form-field" promptText="Enter your position"/>
                </VBox>
            </VBox>

            <!-- Participant-specific fields -->
            <VBox fx:id="participantFields" spacing="15.0" visible="false" managed="false">
                <VBox spacing="5.0">
                    <Label styleClass="form-label" text="Institution"/>
                    <TextField fx:id="institutionField" styleClass="form-field" promptText="Enter your institution"/>
                </VBox>
            </VBox>

            <!-- Terms and Conditions -->
            <CheckBox fx:id="termsCheckbox" styleClass="remember-checkbox" 
                     text="I agree to the Terms and Conditions"/>

            <!-- Buttons -->
            <VBox spacing="10.0">
                <Button fx:id="registerButton" styleClass="primary-button" text="Create Account" 
                       maxWidth="Infinity" disable="true"/>
                
                <HBox alignment="CENTER" spacing="10.0">
                    <ProgressIndicator fx:id="loadingIndicator" visible="false" prefHeight="20.0" prefWidth="20.0"/>
                    <Label fx:id="statusLabel" visible="false"/>
                </HBox>
            </VBox>

            <!-- Error Box -->
            <VBox fx:id="errorBox" spacing="5.0" styleClass="error-box" visible="false">
                <Label fx:id="errorLabel" styleClass="error-label"/>
            </VBox>

            <!-- Back to Login -->
            <VBox alignment="CENTER" spacing="5.0">
                <Label styleClass="footer-text" text="Already have an account?"/>
                <Hyperlink fx:id="loginLink" text="Sign In" underline="true"/>
            </VBox>
        </VBox>
    </VBox>
</ScrollPane>