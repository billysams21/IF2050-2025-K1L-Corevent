<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.corevent.controller.BrowseEventsController" spacing="20" style="-fx-background-color: #f7f9fa; -fx-padding: 32;">
    <HBox alignment="CENTER_LEFT" spacing="18">
        <Label text="Browse Events" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Button fx:id="backButton" text="Back" styleClass="button-secondary" onAction="#handleBack"/>
    </HBox>

    <!-- Search and Filter Section -->
    <VBox spacing="12" style="-fx-background-color: #fff; -fx-background-radius: 12; -fx-padding: 24; -fx-effect: dropshadow(gaussian, #d0d7de, 8, 0, 0, 2);">
        <HBox spacing="12" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="Search events..." HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="eventTypeFilter" promptText="Event Type" prefWidth="150"/>
            <ComboBox fx:id="dateFilter" promptText="Date Range" prefWidth="150"/>
            <Button fx:id="searchButton" text="Search" styleClass="button-primary" onAction="#handleSearch"/>
        </HBox>
    </VBox>

    <!-- Events Table -->
    <TableView fx:id="eventsTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10; -fx-background-color: #fff; -fx-effect: dropshadow(gaussian, #d0d7de, 8, 0, 0, 2);">
        <columns>
            <TableColumn fx:id="eventNameColumn" text="Event Name" prefWidth="200"/>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="150"/>
            <TableColumn fx:id="locationColumn" text="Location" prefWidth="150"/>
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="100"/>
            <TableColumn fx:id="priceColumn" text="Price" prefWidth="100"/>
            <TableColumn fx:id="availableSlotsColumn" text="Available Slots" prefWidth="120"/>
            <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="150"/>
        </columns>
    </TableView>

    <!-- Pagination -->
    <HBox alignment="CENTER" spacing="12">
        <Button fx:id="prevPageButton" text="Previous" styleClass="button-secondary" onAction="#handlePreviousPage"/>
        <Label fx:id="pageInfoLabel" style="-fx-text-fill: #2c3e50;"/>
        <Button fx:id="nextPageButton" text="Next" styleClass="button-secondary" onAction="#handleNextPage"/>
    </HBox>
</VBox> 