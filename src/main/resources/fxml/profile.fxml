<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.corevent.controller.ProfileController" spacing="10" padding="20">
    <Label text="My Profile" styleClass="header-label"/>
    <TextField fx:id="nameField" promptText="Full Name" />
    <TextField fx:id="emailField" promptText="Email" />
    <TextField fx:id="phoneField" promptText="Phone Number" />
    <HBox spacing="10">
        <Button text="Save" onAction="#handleSave" styleClass="button-primary"/>
        <Button text="Cancel" onAction="#handleCancel" styleClass="button-secondary"/>
    </HBox>
</VBox> 