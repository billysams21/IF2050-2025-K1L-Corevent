<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.corevent.controller.BuyTicketController" spacing="20" style="-fx-background-color: #f7f9fa; -fx-padding: 32;">
    <HBox alignment="CENTER_LEFT" spacing="18">
        <Label text="Buy Ticket" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Button fx:id="cancelButton" text="Cancel" styleClass="button-secondary" onAction="#handleCancel"/>
    </HBox>

    <!-- Event Details -->
    <VBox spacing="12" style="-fx-background-color: #fff; -fx-background-radius: 12; -fx-padding: 24; -fx-effect: dropshadow(gaussian, #d0d7de, 8, 0, 0, 2);">
        <Label text="Event Details" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <GridPane hgap="12" vgap="12">
            <Label text="Event Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <Label fx:id="eventNameLabel" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            
            <Label text="Date:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <Label fx:id="eventDateLabel" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            
            <Label text="Location:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <Label fx:id="eventLocationLabel" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
            
            <Label text="Price:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <Label fx:id="eventPriceLabel" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
            
            <Label text="Available Slots:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <Label fx:id="availableSlotsLabel" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        </GridPane>
    </VBox>

    <!-- Payment Details -->
    <VBox fx:id="paymentDetailsBox" spacing="12" style="-fx-background-color: #fff; -fx-background-radius: 12; -fx-padding: 24; -fx-effect: dropshadow(gaussian, #d0d7de, 8, 0, 0, 2);">
        <Label text="Payment Details" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <GridPane hgap="12" vgap="12">
            <Label text="Payment Method:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <ComboBox fx:id="paymentMethodCombo" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="200"/>
            
            <Label text="Transaction Reference:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="transactionRefField" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="200"/>
            
            <Label text="Payment Proof:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <HBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="2">
                <TextField fx:id="paymentProofField" prefWidth="200" editable="false"/>
                <Button fx:id="uploadButton" text="Upload" styleClass="button-secondary" onAction="#handleUploadProof"/>
            </HBox>
        </GridPane>
    </VBox>

    <!-- Action Buttons -->
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button fx:id="buyButton" text="Buy Ticket" styleClass="button-primary" style="-fx-font-size: 15px; -fx-background-radius: 8; -fx-padding: 8 24;" onAction="#handleBuyTicket"/>
    </HBox>
</VBox> 