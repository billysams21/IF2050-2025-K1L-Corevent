<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.corevent.controller.SendNotificationController">
   <children>
      <!-- Header -->
      <HBox alignment="CENTER_LEFT" styleClass="header-section">
         <children>
            <Label styleClass="header-title" text="Kirim Notifikasi" />
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </HBox>
      
      <!-- Main Content -->
      <ScrollPane fitToWidth="true" styleClass="content-scroll">
         <content>
            <VBox spacing="20.0">
               <!-- Event Selection Section -->
               <VBox spacing="10.0" styleClass="form-section">
                  <children>
                     <Label styleClass="section-title" text="Pilih Acara" />
                     <ComboBox fx:id="eventComboBox" maxWidth="1.7976931348623157E308" promptText="-- Pilih Acara --" styleClass="form-field" />
                  </children>
               </VBox>
               
               <!-- Notification Content Section -->
               <VBox spacing="15.0" styleClass="form-section">
                  <children>
                     <Label styleClass="section-title" text="Konten Notifikasi" />
                     
                     <!-- Title Field -->
                     <VBox spacing="5.0">
                        <children>
                           <Label styleClass="form-label" text="Judul Notifikasi:" />
                           <TextField fx:id="titleField" promptText="Contoh: Pengingat Pembayaran" styleClass="form-field" />
                        </children>
                     </VBox>
                     
                     <!-- Message Area -->
                     <VBox spacing="5.0">
                        <children>
                           <Label styleClass="form-label" text="Isi Pesan:" />
                           <TextArea fx:id="messageArea" prefRowCount="4" promptText="Tulis isi pesan yang akan dikirim..." styleClass="form-field" wrapText="true" />
                        </children>
                     </VBox>
                  </children>
               </VBox>
               
               <!-- Participant Selection Section -->
               <VBox spacing="15.0" styleClass="form-section">
                  <children>
                     <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <children>
                           <Label styleClass="section-title" text="Pilih Peserta" />
                           <Region HBox.hgrow="ALWAYS" />
                           <Button fx:id="selectAllButton" onAction="#handleSelectAll" styleClass="secondary-button" text="Pilih Semua" />
                           <Button fx:id="deselectAllButton" onAction="#handleDeselectAll" styleClass="secondary-button" text="Batal Pilih" />
                        </children>
                     </VBox>
                     
                     <!-- Participant Table -->
                     <TableView fx:id="participantTable" prefHeight="300.0" styleClass="data-table">
                        <columns>
                           <TableColumn fx:id="selectColumn" prefWidth="60.0" resizable="false" text="Pilih" />
                           <TableColumn fx:id="nameColumn" prefWidth="200.0" text="Nama Lengkap" />
                           <TableColumn fx:id="emailColumn" prefWidth="250.0" text="Email" />
                        </columns>
                        <columnResizePolicy>
                           <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                     </TableView>
                  </children>
               </VBox>
               
               <!-- Action Section -->
               <HBox alignment="CENTER" spacing="20.0" styleClass="action-section">
                  <children>
                     <ProgressIndicator fx:id="loadingIndicator" visible="false" />
                     <Button fx:id="sendButton" onAction="#handleSendNotification" styleClass="primary-button" text="Kirim Notifikasi">
                        <font>
                           <Font name="System Bold" size="14.0" />
                        </font>
                     </Button>
                  </children>
               </HBox>
               
               <!-- Status Section -->
               <HBox alignment="CENTER">
                  <children>
                     <Label fx:id="statusLabel" styleClass="status-label" />
                  </children>
               </HBox>
               
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
               </padding>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</VBox> 