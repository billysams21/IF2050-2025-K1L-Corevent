<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.corevent.controller.ParticipantDashboardController" spacing="28" style="-fx-background-color: #f7f9fa; -fx-padding: 32;">
    <HBox alignment="CENTER_LEFT" spacing="18">
        <Label fx:id="welcomeLabel" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Label fx:id="roleLabel" style="-fx-font-size: 15px; -fx-text-fill: #888;"/>
    </HBox>
    <HBox spacing="32" style="-fx-padding: 18 0 18 0;">
        <VBox style="-fx-background-color: #fff; -fx-background-radius: 12; -fx-padding: 18 32; -fx-effect: dropshadow(gaussian, #d0d7de, 8, 0, 0, 2);">
            <Label text="Registered Events" style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
            <Label fx:id="registeredEventsLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        </VBox>
        <VBox style="-fx-background-color: #fff; -fx-background-radius: 12; -fx-padding: 18 32; -fx-effect: dropshadow(gaussian, #d0d7de, 8, 0, 0, 2);">
            <Label text="Upcoming Events" style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
            <Label fx:id="upcomingEventsLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        </VBox>
        <VBox style="-fx-background-color: #fff; -fx-background-radius: 12; -fx-padding: 18 32; -fx-effect: dropshadow(gaussian, #d0d7de, 8, 0, 0, 2);">
            <Label text="Completed Events" style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
            <Label fx:id="completedEventsLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        </VBox>
    </HBox>
    <Label text="My Events" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-padding: 0 0 8 0;"/>
    <TableView fx:id="eventsTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10; -fx-background-color: #fff; -fx-effect: dropshadow(gaussian, #d0d7de, 8, 0, 0, 2);">
        <columns>
            <TableColumn fx:id="eventNameColumn" text="Event Name" prefWidth="200"/>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="150"/>
            <TableColumn fx:id="locationColumn" text="Location" prefWidth="150"/>
            <TableColumn fx:id="ticketStatusColumn" text="Ticket Status" prefWidth="100"/>
            <TableColumn fx:id="attendanceStatusColumn" text="Attendance" prefWidth="100"/>
            <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="200"/>
        </columns>
    </TableView>
    <HBox spacing="12" alignment="CENTER_RIGHT" style="-fx-padding: 18 0 0 0;">
        <Button fx:id="browseEventsButton" text="Browse Events" styleClass="button-primary" style="-fx-font-size: 15px; -fx-background-radius: 8; -fx-padding: 8 24;" onAction="#handleBrowseEvents"/>
        <Button fx:id="myTicketsButton" text="My Tickets" styleClass="button-secondary" style="-fx-font-size: 15px; -fx-background-radius: 8; -fx-padding: 8 24;" onAction="#handleMyTickets"/>
        <Button fx:id="myEvaluationsButton" text="My Evaluations" styleClass="button-secondary" style="-fx-font-size: 15px; -fx-background-radius: 8; -fx-padding: 8 24;" onAction="#handleMyEvaluations"/>
        <Button fx:id="profileButton" text="Profile" styleClass="button-secondary" style="-fx-font-size: 15px; -fx-background-radius: 8; -fx-padding: 8 24;" onAction="#handleMyProfile"/>
    </HBox>
</VBox>